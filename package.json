{
  "name": "claudebar",
  "version": "0.1.0",
  "description": "Multi-line status bar compositor for Claude Code with widgets and time-based schedules",
  "type": "module",
  "bin": {
    "claudebar": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --loader ts-node/esm src/cli/index.ts",
    "start": "node dist/cli/index.js"
  },
  "keywords": [
    "claude",
    "claude-code",
    "statusline",
    "statusbar"
  ],
  "author": "gomeslucasm",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gomeslucasm/claudebar.git"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "chalk": "^5.6.2"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3"
  }
}
